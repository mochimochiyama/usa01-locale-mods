# ヒント本文 - Phase 1
msgctxt "osawari_hint"
msgid "ticket_breath_p1_operation"
msgstr "・摸脸颊：点击\n・捏脸颊：拖动\n・摸头：点击"

msgctxt "osawari_hint"
msgid "ticket_breath_p1_hint"
msgstr "揉捏脸颊10次后进入下一阶段"

# ヒント本文 - Phase 2
msgctxt "osawari_hint"
msgid "ticket_breath_p2_operation"
msgstr "・触碰嘴唇：点击\n・把手指伸进嘴里：拖动\n・摸脸颊：点击脸颊\n・捏脸颊：向下拖动脸颊\n・摸头：点击头部"

msgctxt "osawari_hint"
msgid "ticket_breath_p2_hint"
msgstr "伸入手指后进入下一阶段"

# ヒント本文 - Phase 3
msgctxt "osawari_hint"
msgid "ticket_breath_p3_operation"
msgstr "・触碰嘴唇(?)：手指伸入深处时点击\n・把手指伸进嘴里：拖动\n・摸脸颊：点击脸颊\n・捏脸颊：向下拖动脸颊\n・摸头：点击头部"

msgctxt "osawari_hint"
msgid "ticket_breath_p3_hint"
msgstr "触碰嘴唇(?)10次后进入下一阶段"

# ヒント本文 - Phase 4
msgctxt "osawari_hint"
msgid "ticket_breath_p4_operation1"
msgstr "・触碰门牙：点击 (仅在露出门牙时)\n・触碰舌头：点击\n・撑开嘴巴：点击嘴角左右两侧并拖动\n・拉舌头：在张嘴状态下点击舌尖并拖动"

msgctxt "osawari_hint"
msgid "ticket_breath_p4_operation2"
msgstr "・摸脸颊：点击脸颊\n・捏脸颊：向下拖动脸颊\n・摸头：点击头部"

msgctxt "osawari_hint"
msgid "ticket_breath_p4_hint"
msgstr "触碰门牙10次后结束\n手指在嘴里时无法触碰门牙，请通过摸头或摸脸颊让其露出牙齿。"

