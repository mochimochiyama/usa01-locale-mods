msgctxt "merchant_speech"
msgid "locked"
msgstr "...♥"

msgctxt "merchant_speech"
msgid "restock"
msgstr "I got new stuff~"

msgctxt "merchant_speech"
msgid "purchase_thanks_0"
msgstr "Thanks as always~♥"

msgctxt "merchant_speech"
msgid "purchase_thanks_1"
msgstr "Thanks so much~"

msgctxt "merchant_speech"
msgid "purchase_thanks_2"
msgstr "Thanks~"

msgctxt "merchant_speech"
msgid "first_morning"
msgstr "Over here~"

msgctxt "merchant_speech"
msgid "first_day_farewell"
msgstr "Good luck~♥"

msgctxt "merchant_speech"
msgid "greeting"
msgstr "Hey there~"

# === Merchant Chat (Shop Level) ===
msgctxt "merchant_chat_shop"
msgid "lv0_0"
msgstr "Oh, you're here again~?"

msgctxt "merchant_chat_shop"
msgid "lv0_1"
msgstr "Going on a quest~?\nAre you~?"

msgctxt "merchant_chat_shop"
msgid "lv0_2"
msgstr "I have just the right thing for you~ Mr. Adventurer~"

msgctxt "merchant_chat_shop"
msgid "lv0_3"
msgstr "Gotta clean up~"

msgctxt "merchant_chat_shop"
msgid "lv0_4"
msgstr "I sell stuff\nfor beginners too~"

msgctxt "merchant_chat_shop"
msgid "lv0_5"
msgstr "Within your budget~?"


msgctxt "merchant_chat_shop"
msgid "lv1_0"
msgstr "I'm slowly expanding my lineup~"

msgctxt "merchant_chat_shop"
msgid "lv1_1"
msgstr "Buy more expensive stuff, okay~?"

msgctxt "merchant_chat_shop"
msgid "lv1_2"
msgstr "Function over... form~? You might regret buying things just based on the looks~"

msgctxt "merchant_chat_shop"
msgid "lv1_3"
msgstr "I thought I restocked this rack yesterday~"

msgctxt "merchant_chat_shop"
msgid "lv1_4"
msgstr "Are you the kind that can make do with the cheap stuff~?"


msgctxt "merchant_chat_shop"
msgid "lv2_0"
msgstr "Busy recently~?"

msgctxt "merchant_chat_shop"
msgid "lv2_1"
msgstr "You look better equipped than before, hmm~?"

msgctxt "merchant_chat_shop"
msgid "lv2_2"
msgstr "Maybe it's time for a gear upgrade~?"

msgctxt "merchant_chat_shop"
msgid "lv2_3"
msgstr "You're here everyday, huh~?"

msgctxt "merchant_chat_shop"
msgid "lv2_4"
msgstr "Getting used to that gear~? You were fumbling around in it at first~"

msgctxt "merchant_chat_shop"
msgid "lv2_5"
msgstr "Huh~ I don't remember moving the shelves~..."

msgctxt "merchant_chat_shop"
msgid "lv2_6"
msgstr "Don't go too hard on yourself~ Not goof for me if you die~ I think."

msgctxt "merchant_chat_shop"
msgid "lv2_7"
msgstr "What do you need next~ I wonder..."

msgctxt "merchant_chat_shop"
msgid "lv2_8"
msgstr "The stock around these racks runs out so fast~"

msgctxt "merchant_chat_shop"
msgid "lv2_9"
msgstr "I'll need to stock up on that, but before that, this too~..."



msgctxt "merchant_chat_shop"
msgid "lv3_0"
msgstr "You're not half bad~"

msgctxt "merchant_chat_shop"
msgid "lv3_1"
msgstr "Is the price tag right...? I'll check later."

msgctxt "merchant_chat_shop"
msgid "lv3_2"
msgstr "You move like an adventurer now~... kinda?"

msgctxt "merchant_chat_shop"
msgid "lv3_3"
msgstr "Good choice~"

msgctxt "merchant_chat_shop"
msgid "lv3_4"
msgstr "Morning~"

msgctxt "merchant_chat_shop"
msgid "lv3_5"
msgstr "Help me get rid of that box, okay~?"

msgctxt "merchant_chat_shop"
msgid "lv3_6"
msgstr "Huh~ People normally don't go on that quest~"

msgctxt "merchant_chat_shop"
msgid "lv3_7"
msgstr "Don't get caught off guard〜"






msgctxt "merchant_chat_shop"
msgid "lv4_0"
msgstr "I placed the order right~ I hope~?"

msgctxt "merchant_chat_shop"
msgid "lv4_1"
msgstr "The bill... Where did I put it..."

msgctxt "merchant_chat_shop"
msgid "lv4_2"
msgstr "Need to come up with new lineup~"

msgctxt "merchant_chat_shop"
msgid "lv4_3"
msgstr "Mornie~"

msgctxt "merchant_chat_shop"
msgid "lv4_4"
msgstr "Oh~ That fits you well~ Kinda~?"

msgctxt "merchant_chat_shop"
msgid "lv4_5"
msgstr "Ah, the price tag is out of place..."

msgctxt "merchant_chat_shop"
msgid "lv4_6"
msgstr "Thanks a bunch~ for buying here so often~"

msgctxt "merchant_chat_shop"
msgid "lv4_7"
msgstr "What should I stock up on, next~? ...This, I guess~"

msgctxt "merchant_chat_shop"
msgid "lv4_8"
msgstr "You went on a quest like that~? Ew..."


msgctxt "merchant_chat_shop"
msgid "lv5_0"
msgstr "Mornin'~"

msgctxt "merchant_chat_shop"
msgid "lv5_1"
msgstr "Business, booming~♥"

msgctxt "merchant_chat_shop"
msgid "lv5_2"
msgstr "Don't need me to tell you what to do~ Just buy~♥"

msgctxt "merchant_chat_shop"
msgid "lv5_3"
msgstr "What did you beat up...? Woah..."

msgctxt "merchant_chat_shop"
msgid "lv5_4"
msgstr "You've gotten very adventurer-like~ before I knew it, huh~?"

msgctxt "merchant_chat_shop"
msgid "lv5_5"
msgstr "Don't go on such a risky quest~"

msgctxt "merchant_chat_shop"
msgid "lv5_6"
msgstr "Morn~"

msgctxt "merchant_chat_shop"
msgid "lv5_7"
msgstr "Help me clean my room again~"

msgctxt "merchant_chat_shop"
msgid "lv5_8"
msgstr "Ehh~ Just take things easy~♥"

msgctxt "merchant_chat_shop"
msgid "lv5_9"
msgstr "Buy something~"

msgctxt "merchant_chat_shop"
msgid "lv5_10"
msgstr "Clean up that rack~"

msgctxt "merchant_chat_shop"
msgid "lv5_11"
msgstr "The monsters are dwindling, apparently~"

msgctxt "merchant_chat_shop"
msgid "lv5_12"
msgstr "I'm feeling lazy today~"

msgctxt "merchant_chat_shop"
msgid "lv5_13"
msgstr "My shop has gotten bigger~ way bigger than when I started out, huh~?"

msgctxt "merchant_chat_shop"
msgid "lv5_14"
msgstr "Oh, it's messy there~ Careful~"

msgctxt "merchant_chat_shop"
msgid "lv5_15"
msgstr "Seeya~"

msgctxt "merchant_chat_shop"
msgid "lv5_16"
msgstr "Not doing much today~?"

msgctxt "merchant_chat_shop"
msgid "lv5_17"
msgstr "You looked so weird in that gear at first~ Now it feels normal~"

msgctxt "merchant_chat_shop"
msgid "lv5_18"
msgstr "Sit there and wait, okay~?"




# === Merchant Chat (Quest Progress) ===
msgctxt "merchant_chat_quest"
msgid "0_0"
msgstr "You beat a slime, huh~? The great first step~"

msgctxt "merchant_chat_quest"
msgid "0_1"
msgstr "Good to see you in one piece, Mr. Adventurer~\n...Not dying so fast,\nyou say~?"

msgctxt "merchant_chat_quest"
msgid "0_2"
msgstr "Don't let your guard down just because it's a slime~"

msgctxt "merchant_chat_quest"
msgid "0_3"
msgstr "It all begins with a slime~"



msgctxt "merchant_chat_quest"
msgid "1_0"
msgstr "Well, goblins are no match for you~ I knew it~"

msgctxt "merchant_chat_quest"
msgid "1_1"
msgstr "Things get messy when monsters group up~ Especially so for goblins..."

msgctxt "merchant_chat_quest"
msgid "1_2"
msgstr "Don't get too ahead of yourself~ Okay~?"



msgctxt "merchant_chat_quest"
msgid "2_0"
msgstr "Skeletons are just small fry, hmm~?"

msgctxt "merchant_chat_quest"
msgid "2_1"
msgstr "Cracking some bones now? I see~"

msgctxt "merchant_chat_quest"
msgid "2_2"
msgstr "Hmmm~ Looks like you're starting to get your hands on some better monster materials."


msgctxt "merchant_chat_quest"
msgid "3_0"
msgstr "Imps? Not much of a challenge, huh~?"

msgctxt "merchant_chat_quest"
msgid "3_1"
msgstr "Getting the hang of things~?"

msgctxt "merchant_chat_quest"
msgid "3_2"
msgstr "You accepted that quest, huh~?"


msgctxt "merchant_chat_quest"
msgid "4_0"
msgstr "You beat an orc? Wow~"

msgctxt "merchant_chat_quest"
msgid "4_1"
msgstr "Orcs actually taste good, they say~"



msgctxt "merchant_chat_quest"
msgid "5_0"
msgstr "Harpies are just so annoying, right~?"

msgctxt "merchant_chat_quest"
msgid "5_1"
msgstr "How are you doing against the monsters of the sky~?"

msgctxt "merchant_chat_quest"
msgid "5_2"
msgstr "Harpy feathers~"


msgctxt "merchant_chat_quest"
msgid "6_0"
msgstr "Troll fangs~ Authentic ones~?"

msgctxt "merchant_chat_quest"
msgid "6_1"
msgstr "You're getting pretty strong~ Aren't you~?"


msgctxt "merchant_chat_quest"
msgid "7_0"
msgstr "Golems~? Gee~"

msgctxt "merchant_chat_quest"
msgid "7_1"
msgstr "Fighting a golem head-on~? Are you stupid~?♥"


msgctxt "merchant_chat_quest"
msgid "8_0"
msgstr "Wvyerns can fly~ How'd you beat them~?"

msgctxt "merchant_chat_quest"
msgid "8_1"
msgstr "These materials are kinda useless〜♥"


msgctxt "merchant_chat_quest"
msgid "9_0"
msgstr "Nagas… Never heard of them before~♥"

msgctxt "merchant_chat_quest"
msgid "9_1"
msgstr "What's this material~?"


msgctxt "merchant_chat_quest"
msgid "10_0"
msgstr "Krakens are actually beatable~?"

msgctxt "merchant_chat_quest"
msgid "10_1"
msgstr "Are you sure beating a kraken won't cause problems~?"


msgctxt "merchant_chat_quest"
msgid "11_0"
msgstr "Golden dragon~♥"
