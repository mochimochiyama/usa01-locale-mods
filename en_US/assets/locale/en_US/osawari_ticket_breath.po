# ヒント本文 - Phase 1
msgctxt "osawari_hint"
msgid "ticket_breath_p1_operation"
msgstr "- Touch cheeks: Left click\n- Pull cheeks: Drag\n- Pat head: Left click"

msgctxt "osawari_hint"
msgid "ticket_breath_p1_hint"
msgstr "Touch her cheeks 10 times to continue."

# ヒント本文 - Phase 2
msgctxt "osawari_hint"
msgid "ticket_breath_p2_operation"
msgstr "- Touch lips: Left click\n- Finger in mouth: Drag\n- Touch cheeks: Left click\n- Pull cheeks: Drag\n- Pat head: Left Click"

msgctxt "osawari_hint"
msgid "ticket_breath_p2_hint"
msgstr "Insert your finger in her mouth to continue."

# ヒント本文 - Phase 3
msgctxt "osawari_hint"
msgid "ticket_breath_p3_operation"
msgstr "- Touch lips (?): Left click after fully inserting finger\n- Finger in mouth: Drag\n- Touch cheeks: Left click\n- Pull cheeks: Drag\n- Pat head: Left Click"

msgctxt "osawari_hint"
msgid "ticket_breath_p3_hint"
msgstr "Touch her lips (?) 10 times to continue."

# ヒント本文 - Phase 4
msgctxt "osawari_hint"
msgid "ticket_breath_p4_operation1"
msgstr "- Touch front teeth: Left click (only when visible)\n- Touch tongue: Left click\n- Finger in mouth: Left click and drag mouth sides\n- Pull tongue: Left click and drag the tip of the tongue while mouth is open"

msgctxt "osawari_hint"
msgid "ticket_breath_p4_operation2"
msgstr "- Touch cheeks: Left click cheeks\n- Pull cheeks: Drag cheeks downward\n- Pat head: Left click head"

msgctxt "osawari_hint"
msgid "ticket_breath_p4_hint"
msgstr "Ends when you touch her front teeth 10 times.\nYou won't be able to touch her front teeth if your finger is inside her mouth. Try patting her head or touching her cheeks to get her to show her teeth."

