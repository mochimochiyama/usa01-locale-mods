# ヒント本文 - Phase 1
msgctxt "osawari_hint"
msgid "ticket_breath_p1_operation"
msgstr "・摸臉頰：點擊\n・捏臉頰：拖曳\n・摸摸頭：點擊"

msgctxt "osawari_hint"
msgid "ticket_breath_p1_hint"
msgstr "揉臉頰10次後進入下一段劇情"

# ヒント本文 - Phase 2
msgctxt "osawari_hint"
msgid "ticket_breath_p2_operation"
msgstr "・摸嘴唇：點擊\n・把手指伸進嘴裡：拖曳\n・摸臉頰：點擊臉頰\n・捏臉頰：向下拖曳臉頰\n・摸摸頭：點擊頭部"

msgctxt "osawari_hint"
msgid "ticket_breath_p2_hint"
msgstr "把手指伸進去後進入下一段劇情"

# ヒント本文 - Phase 3
msgctxt "osawari_hint"
msgid "ticket_breath_p3_operation"
msgstr "・摸嘴唇？：把手指伸到最裡面並點擊\n・把手指伸進嘴裡：拖曳\n・摸臉頰：點擊臉頰\n・捏臉頰：向下拖曳臉頰\n・摸摸頭：點擊頭部"

msgctxt "osawari_hint"
msgid "ticket_breath_p3_hint"
msgstr "摸嘴唇？10次後進入下一段劇情"

# ヒント本文 - Phase 4
msgctxt "osawari_hint"
msgid "ticket_breath_p4_operation1"
msgstr "・摸門牙：點擊 (只有在看得到門牙時)\n・摸舌頭：點擊\n・伸進手指：點擊嘴巴左右兩側並拖曳\n・拉舌頭：在嘴巴張開的狀態下，點擊舌尖並拖曳"

msgctxt "osawari_hint"
msgid "ticket_breath_p4_operation2"
msgstr "・摸臉頰：點擊臉頰\n・捏臉頰：向下拖曳臉頰\n・摸摸頭：點擊頭部"

msgctxt "osawari_hint"
msgid "ticket_breath_p4_hint"
msgstr "摸門牙10次後結束\n如果手指伸進嘴裡會摸不到門牙，請藉由摸摸頭或摸臉頰來讓門牙露出來。"

